generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  nome       String
  telefone   String   @unique
  endereco   String
  usuario    String   @unique
  senha      String
  role       String   @default("OPERARIO")
  etapas     Etapa[]  @relation("EtapaFuncionarios")
  createdAt  DateTime @default(now())
}

model Aeronave {
  id          Int      @id @default(autoincrement())
  modelo      String   @default("COMERCIAL")
  capacidade  String
  alcance     String
  etapas      Etapa[]
  pecas       Peca[]   @relation("AeronavePecas")
  testes      Testes[]
  createdAt   DateTime @default(now())
}

model Testes {
  id             Int       @id @default(autoincrement())
  aerodinamico   String    @default("REPROVADO")
  eletrico       String    @default("REPROVADO")
  hidraulico     String    @default("REPROVADO")
  aeronaveid     Int
  aeronave       Aeronave  @relation(fields: [aeronaveid], references: [id])
  createdAt      DateTime  @default(now())
}

model Etapa {
  id             Int       @id @default(autoincrement())
  nome           String
  prazo          DateTime
  status         String    @default("EM_ANDAMENTO")
  funcionarios   User[]    @relation("EtapaFuncionarios")
  aeronaveid     Int
  aeronave       Aeronave  @relation(fields: [aeronaveid], references: [id])
  createdAt      DateTime  @default(now())
}

model Peca {
  id           Int         @id @default(autoincrement())
  nome         String
  tipo         String
  fornecedor   String
  status       String      @default("EM_TRANSITO")
  aeronaves    Aeronave[]  @relation("AeronavePecas")
  createdAt    DateTime    @default(now())
}